{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
        "linux": "script=; for root in \"$PLUGIN_ROOT\" \"$CURSOR_PLUGIN_ROOT\" \"$PWD\" \"$HOME/.vscode/agent-plugins\" \"$HOME/.cursor/agent-plugins\"; do [ -n \"$root\" ] || continue; if [ -f \"$root/hooks/scripts/check-and-update.py\" ] && [ -f \"$root/plugin.json\" ]; then script=\"$root/hooks/scripts/check-and-update.py\"; break; fi; found=$(find \"$root\" -path '*/hooks/scripts/check-and-update.py' -type f 2>/dev/null | head -n 1); if [ -n \"$found\" ] && [ -f \"$(dirname \"$(dirname \"$(dirname \"$found\")\")\")/plugin.json\" ]; then script=\"$found\"; break; fi; done; [ -n \"$script\" ] || { echo 'Cannot locate cim-skills check-and-update.py'; exit 1; }; python3 \"$script\""
      }
    ]
  }
}